<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] bg-white">
  <div class="card w-full max-w-md shadow-2xl bg-base-200">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold justify-center mb-6">Log in</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-control gap-2">
          <%= f.label :email, class: "label" do %>
            <span class="label-text font-semibold">Email</span>
          <% end %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full focus:input-primary" %>
        </div>

        <div class="form-control gap-2 mt-4">
          <%= f.label :password, class: "label" do %>
            <span class="label-text font-semibold">Password</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full focus:input-primary" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control mt-4">
            <label class="label cursor-pointer justify-start gap-3 w-fit">
              <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
              <span class="label-text">Remember me</span>
            </label>
          </div>
        <% end %>

        <div class="form-control mt-6">
          <%= f.submit "Log in", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider mt-6"></div>
      
      <div class="flex flex-col gap-2 text-center text-sm link-primary">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
