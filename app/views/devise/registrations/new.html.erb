<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] bg-white">
  <div class="card w-full max-w-md shadow-2xl bg-base-100">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold justify-center mb-6">Sign up</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="mb-4 text-error text-sm">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>

        <div class="form-control gap-2">
          <%= f.label :email, class: "label" do %>
            <span class="label-text font-semibold">Email</span>
          <% end %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full focus:input-primary" %>
        </div>

        <div class="form-control gap-2">
          <%= f.label :first_name, class: "label" do %>
            <span class="label-text font-semibold">First Name</span>
          <% end %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "first_name", class: "input input-bordered w-full focus:input-primary" %>
        </div>

        <div class="form-control gap-2">
          <%= f.label :last_name, class: "label" do %>
            <span class="label-text font-semibold">Last Name</span>
          <% end %>
          <%= f.text_field :last_name, autofocus: true, autocomplete: "last_name", class: "input input-bordered w-full focus:input-primary" %>
        </div>

        <div class="form-control gap-2 mt-4">
          <%= f.label :password, class: "label" do %>
            <span class="label-text font-semibold">Password</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "input input-bordered w-full focus:input-primary" %>
          <% if @minimum_password_length %>
            <label class="label py-0">
              <span class="label-text-alt text-base-content/70">(<%= @minimum_password_length %> characters minimum)</span>
            </label>
          <% end %>
        </div>

        <div class="form-control gap-2 mt-4">
          <%= f.label :password_confirmation, class: "label" do %>
            <span class="label-text font-semibold">Confirm Password</span>
          <% end %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full focus:input-primary" %>
        </div>

        <div class="form-control mt-8">
          <%= f.submit "Sign up", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider mt-6"></div>
      
      <div class="flex flex-col gap-2 text-center text-sm link-primary">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
