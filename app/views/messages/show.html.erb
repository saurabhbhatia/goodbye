<div class="container mx-auto p-4 max-w-2xl mt-8">
  <% if notice.present? %>
    <div class="alert alert-success shadow-sm mb-6">
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="card bg-base-200 shadow-xl">
    <div class="card-body">
      <%= render @message %>

      <div class="divider"></div>

      <div class="card-actions justify-end items-center flex-row flex-nowrap">
        <%= link_to "Edit this message", edit_message_path(@message), class: "btn btn-primary btn-sm" %>
        <%= link_to "Back to messages", messages_path, class: "btn btn-ghost btn-sm" %>
        <div class="ml-auto">
          <%= button_to "Destroy this message", @message, method: :delete, class: "btn btn-error btn-sm" %>
        </div>
      </div>
    </div>
  </div>
</div>
