<div id="<%= dom_id message %>" class="flex flex-col gap-3">
  <div>
    <h3 class="text-sm font-semibold text-base-content/70 uppercase tracking-wider">User</h3>
    <p class="text-lg"><%= message.user_id %></p>
  </div>

  <div>
    <h3 class="text-sm font-semibold text-base-content/70 uppercase tracking-wider">Body</h3>
    <div class="bg-base-100 p-4 rounded-lg shadow-inner mt-1">
      <%= message.body %>
    </div>
  </div>

  <div>
    <h3 class="text-sm font-semibold text-base-content/70 uppercase tracking-wider">Image</h3>
    <div class="bg-base-100 p-4 rounded-lg shadow-inner mt-1">
      <%= image_tag message.image %>
    </div>
  </div>
</div>
